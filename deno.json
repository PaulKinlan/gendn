{
  "license": "Apache-2.0",
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-env server.ts",
    "start": "deno run --allow-net --allow-read --allow-env server.ts",
    "check": "deno check server.ts",
    "fmt": "deno fmt"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "semiColons": true,
    "exclude": ["**/*.html", "**/*.css"]
  },
  "compilerOptions": {
    "lib": ["deno.window", "dom"],
    "strict": true
  }
}
